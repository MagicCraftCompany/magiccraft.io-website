# Copy to an ignored local environment file or configure in Netlify.
# Never commit real keys, tokens, wallet secrets, or private endpoints.

## Live Support, server-side Netlify Function
OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini

## Sanity public blog reads, bundled into the browser
VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=your-dataset-name
VITE_SANITY_API_VERSION=2023-05-03

# Do not configure VITE_SANITY_API_TOKEN. Every VITE_ value is exposed to the
# browser, so privileged Sanity operations must move behind a server endpoint.

## GameServer, server-side Netlify Functions
# GAMESERVER_API_URL=https://approved-gameserver-proxy.example
GAMESERVER_API_PORT=8903
GAMESERVER_API_KEY=your_server_side_key_here
# GAMESERVER_API_TIMEOUT_MS=5000

## Game stats source overrides and time budgets
# LOBBY_STATS_URL=https://lobby-api-prod.magiccraft.io/stats
# LOBBY_API_TIMEOUT_MS=5000
# MARKET_API_TIMEOUT_MS=5000

## Grant intake
# Netlify supplies URL and DEPLOY_PRIME_URL automatically in its runtime.
# GRANTS_FORM_ENDPOINT=https://your-reviewed-intake-endpoint.example
# GRANTS_FORM_TIMEOUT_MS=8000

## Best-effort MCRT social mentions
# MCRT_MENTIONS_REQUEST_TIMEOUT_MS=1200
# MCRT_MENTIONS_TOTAL_TIMEOUT_MS=5000
# MCRT_MENTIONS_MAX_HOSTS=4

## Development-only battle-pass fixture
# VITE_USE_MOCK_BATTLEPASS=false
